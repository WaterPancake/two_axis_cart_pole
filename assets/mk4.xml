<!-- mk4: ball-joint pole.

     mk2 modeled the pole with two stacked hinges (a universal joint). That
     parameterization has an intrinsic coordinate singularity when the second
     hinge reaches +/- 90 degrees (pole parallel to the ground): representing
     finite tip motion requires unbounded hinge rates, and the armature that
     regularized the mass matrix stored spurious kinetic energy that was
     exchanged with the physical coordinates near the singularity.

     A ball joint parameterizes orientation with a quaternion, so the dynamics
     are smooth for every pole direction and no armature is needed on the pole.
     The extra twist degree of freedom (rotation about the pole's own axis) is
     unactuated, torque-free for this axisymmetric pole, and lightly damped.

     Physical parameters (masses, lengths, gear, slider damping/armature)
     are identical to mk2 so controllers tuned against mk2 carry over.
     envs/mujoco_interface.py converts between the quaternion state and the
     (theta_x, theta_y) universal-joint convention used by the controllers:
     pole direction p = [sin(tx)cos(ty), -sin(ty), cos(tx)cos(ty)]. -->
<mujoco model="inverted two-axis pendulum mk4">
  <compiler inertiafromgeom="true"/>
  <option gravity="0 0 -9.81" timestep="0.002" integrator="implicitfast">
    <flag energy="enable"/>
  </option>
  <default>
    <joint damping="0"/>
    <motor ctrlrange="-1 1"/>
    <!-- Nothing in the workspace can ever touch: the cart rides at z=0 and the
         tip's lowest point (z=-0.65) stays above the floor (z=-0.75). -->
    <geom contype="0" conaffinity="0"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.8 0.8 0.8" rgb2="0 0 0" width="512" height="3072"/>
    <texture name="floor_tex" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 .2 .3" width="100" height="100"/>
    <material name="floor_material" texture="floor_tex" texuniform="true"/>
  </asset>

  <worldbody>
    <light cutoff="100" diffuse="1 1 1" dir="-0 0 -1.2" directional="true" exponent="1" pos="0 0 1.3" specular=".1 .1 .1"/>
    <geom material="floor_material" name="floor" pos="0 0 -0.75" size="40 40 40" type="plane" rgba="0.5 0.5 0.5 1.0"/>
    <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1"/>

    <geom pos="0 10.2 0" quat="0.707 0 0.707 0" size="0.02 10.2" type="capsule" rgba="1 1 1 1"/>
    <geom pos="0 -10.2 0" quat="0.707 0 0.707 0" size="0.02 10.2" type="capsule" rgba="1 1 1 1"/>
    <geom pos="10.2 0 0" quat="0.707 0.707 0 0" size="0.02 10.2" type="capsule" rgba="1 1 1 1"/>
    <geom pos="-10.2 0 0" quat="0.707 0.707 0 0" size="0.02 10.2" type="capsule" rgba="1 1 1 1"/>

    <body name="cart" pos="0 0 0">
      <joint axis="1 0 0" limited="true" name="x_slider" pos="0 0 0" range="-10 10"
             type="slide" damping="0.4" armature="0.02" margin="0.2"
             solreflimit="0.08 1" solimplimit="0.7 0.95 0.02 0.5 2"/>
      <joint axis="0 1 0" limited="true" name="y_slider" pos="0 0 0" range="-10 10"
             type="slide" damping="0.4" armature="0.02" margin="0.2"
             solreflimit="0.08 1" solimplimit="0.7 0.95 0.02 0.5 2"/>
      <geom name="cart" pos="0 0 0" quat="0.707 0 0.707 0" size="0.1 0.1 0.1" type="box" mass="1"/>

      <body name="pole" pos="0 0 0">
        <joint name="pole_ball" type="ball" pos="0 0 0" damping="0.01"/>
        <geom fromto="0 0 0 0 0 0.6" name="pole" size="0.02" type="capsule" mass="1e-4"/>

        <geom name="mass" type="sphere" size="0.05" pos="0 0 0.6" mass="0.25"/>
        <site name="mass_site" pos="0 0 0.6" size="0.02" rgba="1 0 0 1"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor ctrllimited="true" ctrlrange="-1 1" gear="10" joint="x_slider" name="x_slide"/>
    <motor ctrllimited="true" ctrlrange="-1 1" gear="10" joint="y_slider" name="y_slide"/>
  </actuator>

  <sensor>
    <jointpos name="x_pos" joint="x_slider"/>
    <jointpos name="y_pos" joint="y_slider"/>
    <ballquat name="pole_quat" joint="pole_ball"/>

    <jointvel name="x_vel" joint="x_slider"/>
    <jointvel name="y_vel" joint="y_slider"/>
    <ballangvel name="pole_angvel" joint="pole_ball"/>

    <actuatorfrc name="x_force" actuator="x_slide"/>
    <actuatorfrc name="y_force" actuator="y_slide"/>

    <framepos name="mass_pos" objtype="site" objname="mass_site"/>
    <framelinvel name="mas_vel" objtype="site" objname="mass_site"/>
  </sensor>
</mujoco>
